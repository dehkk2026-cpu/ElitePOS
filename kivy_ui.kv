<ProductItem>:
size_hint_y: None
height: "100dp"
padding: "8dp"
elevation: 2
ripple_behavior: True
md_bg_color: app.theme_cls.primary_light
вЂ‹MDBoxLayout:
orientation: 'vertical'
MDLabel:
text: root.name
font_style: "H6"
halign: "center"
MDLabel:
text: f"${root.price:.2f}"
halign: "center"
theme_text_color: "Secondary"
вЂ‹<CartItem>:
size_hint_y: None
height: "60dp"
padding: "8dp"
elevation: 1
вЂ‹MDBoxLayout:
orientation: 'horizontal'
MDLabel:
text: root.name
size_hint_x: 0.5
MDLabel:
text: f"x{root.qty}"
size_hint_x: 0.2
halign: "center"
MDLabel:
text: f"${root.price * root.qty:.2f}"
size_hint_x: 0.3
halign: "right"
вЂ‹<CashierScreen>:
MDBoxLayout:
orientation: 'horizontal'
вЂ‹MDBoxLayout:
orientation: 'vertical'
size_hint_x: 0.65
padding: "8dp"
spacing: "8dp"
вЂ‹MDBoxLayout:
size_hint_y: None
height: "50dp"
MDIconButton:
icon: "lock"
on_release: root.manager.current = 'admin'
MDLabel:
text: "Cashier System"
font_style: "H5"
halign: "center"
вЂ‹ScrollView:
MDGridLayout:
id: products_grid
cols: 3
spacing: "10dp"
padding: "10dp"
size_hint_y: None
height: self.minimum_height
вЂ‹MDCard:
orientation: 'vertical'
size_hint_x: 0.35
padding: "8dp"
spacing: "8dp"
elevation: 3
вЂ‹MDLabel:
text: "Current Order"
font_style: "H6"
size_hint_y: None
height: "40dp"
вЂ‹ScrollView:
MDBoxLayout:
id: cart_list
orientation: 'vertical'
size_hint_y: None
height: self.minimum_height
spacing: "4dp"
вЂ‹MDLabel:
id: total_label
text: "Total: $0.00"
font_style: "H5"
halign: "right"
size_hint_y: None
height: "50dp"
theme_text_color: "Primary"
вЂ‹MDGridLayout:
cols: 4
size_hint_y: None
height: "120dp"
spacing: "4dp"
вЂ‹MDRaisedButton:
text: "1"
size_hint: 1, 1
on_release: root.set_quantity('1')
MDRaisedButton:
text: "2"
size_hint: 1, 1
on_release: root.set_quantity('2')
MDRaisedButton:
text: "3"
size_hint: 1, 1
on_release: root.set_quantity('3')
MDRaisedButton:
text: "Clear"
size_hint: 1, 1
md_bg_color: 1, 0, 0, 1
on_release: root.set_quantity('Clear')
MDRaisedButton:
text: "4"
size_hint: 1, 1
on_release: root.set_quantity('4')
MDRaisedButton:
text: "5"
size_hint: 1, 1
on_release: root.set_quantity('5')
MDRaisedButton:
text: "6"
size_hint: 1, 1
on_release: root.set_quantity('6')
MDRaisedButton:
text: "Del"
size_hint: 1, 1
md_bg_color: 0.8, 0.4, 0, 1
on_release: root.clear_cart()
вЂ‹MDRaisedButton:
text: "PAY & PRINT"
font_size: "24sp"
size_hint: 1, None
height: "80dp"
md_bg_color: 0, 0.6, 0, 1
on_release: root.pay_and_print()
вЂ‹<AdminScreen>:
MDBoxLayout:
orientation: 'vertical'
вЂ‹MDTopAppBar:
title: "Admin Panel"
left_action_items: [["arrow-left", lambda x: setattr(root.manager, 'current', 'cashier')]]
вЂ‹MDBottomNavigation:
вЂ‹MDBottomNavigationItem:
name: 'screen_products'
text: 'Products'
icon: 'package-variant'
вЂ‹MDBoxLayout:
orientation: 'vertical'
padding: "16dp"
spacing: "10dp"
вЂ‹MDTextField:
id: prod_name
hint_text: "Product Name"
MDTextField:
id: prod_price
hint_text: "Price"
input_filter: "float"
вЂ‹MDRaisedButton:
text: "Add Product"
on_release: root.add_product()
вЂ‹ScrollView:
MDList:
id: admin_product_list
вЂ‹MDBottomNavigationItem:
name: 'screen_printer'
text: 'Printer'
icon: 'printer-pos'
вЂ‹MDBoxLayout:
orientation: 'vertical'
padding: "16dp"
spacing: "10dp"
вЂ‹MDLabel:
id: printer_status
text: "Status: Disconnected"
halign: "center"
font_style: "H6"
вЂ‹MDRaisedButton:
text: "Scan BLE Printers"
pos_hint: {"center_x": .5}
on_release: root.scan_bluetooth()
вЂ‹ScrollView:
MDList:
id: ble_devices_list
вЂ‹MDBottomNavigationItem:
name: 'screen_stats'
text: 'Statistics'
icon: 'chart-bar'
вЂ‹MDBoxLayout:
orientation: 'vertical'
padding: "16dp"
spacing: "20dp"
вЂ‹MDCard:
orientation: "vertical"
padding: "16dp"
size_hint_y: None
height: "150dp"
вЂ‹MDLabel:
text: "Total Orders"
halign: "center"
MDLabel:
id: total_orders
text: "0"
font_style: "H3"
halign: "center"
вЂ‹MDCard:
orientation: "vertical"
padding: "16dp"
size_hint_y: None
height: "150dp"
вЂ‹MDLabel:
text: "Total Sales"
halign: "center"
MDLabel:
id: total_sales
text: "$0.00"
font_style: "H3"
halign: "center"
вЂ‹MDRaisedButton:
text: "Close Shift (Z-Report)"
md_bg_color: 1, 0, 0, 1
pos_hint: {"center_x": .5}
on_release: root.close_shift()